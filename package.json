{
  "name": "simulador-sistema-flotante",
  "version": "0.2.0",
  "description": "Floating Farm simulator + ESP32 prototype bridge.",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "node --test --test-reporter=spec \"tests/**/*.test.mjs\"",
    "serve": "python -m http.server 3000",
    "firmware:build": "pio run -d firmware/esp32",
    "firmware:upload": "pio run -d firmware/esp32 -t upload",
    "firmware:monitor": "pio device monitor -b 115200"
  }
}
